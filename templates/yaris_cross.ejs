          <li><span>Wireless Charger</span><span>With</span></li>
          <li><span>USB Charger (Type C)</span><span>Type C: 2</span></li>
          <li><span>Audio System Speakers</span><span>6</span></li>
          <li><span>Power Steering</span><span>EPS</span></li>
          <li><span>Front USB (Type A and Type C)</span><span>Type A: 1, Type C: 1</span></li>
