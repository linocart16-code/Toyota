  <h2 style="font-size:2.3rem; color:#d32f2f; margin-bottom:10px;">Hi! I'm Marcel Joseph Chan Claridad</h2>
  <p style="font-size:1.1rem; color:#333; margin-bottom:30px;">A Marketing Professional passionate about creating innovative strategies, building strong brands, and driving business growth. </p>
  <form method="POST" action="/request-quote" style="max-width:540px; margin:0 auto; text-align:left; background:#fff; border-radius:12px; box-shadow:0 2px 16px #0001; padding:32px 28px;">
    <div style="margin-bottom:18px;">
      <label for="qname" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Full Name *</label>
      <input type="text" id="qname" name="qname" required style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
    </div>
    <div style="margin-bottom:18px;">
      <label for="qemail" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Email Address *</label>
      <input type="email" id="qemail" name="qemail" required style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
    </div>
    <div style="margin-bottom:18px;">
      <label for="qphone" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Phone Number *</label>
      <input type="tel" id="qphone" name="qphone" required style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
    </div>
<div style="margin-bottom:18px;">
      <label for="qvehicle" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Vehicle of Interest</label>
<select id="qvehicle" name="qvehicle" style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px; background:#fff;">
        <option value="">Select a vehicle</option>
        <option value="Wigo">Wigo</option>
        <option value="Vios">Vios</option>
        <option value="ATIV">ATIV</option>
        <option value="Corolla Altis">Corolla Altis</option>
        <option value="Camry">Camry</option>
        <option value="Raize">Raize</option>
        <option value="Veloz">Veloz</option>
        <option value="Rush">Rush</option>
        <option value="Corolla Cross">Corolla Cross</option>
        <option value="Yaris Cross">Yaris Cross</option>
        <option value="RAV4">RAV4</option>
        <option value="Fortuner">Fortuner</option>
        <option value="Land Cruiser Prado">Land Cruiser Prado</option>
        <option value="bZ4X">bZ4X</option>
        <option value="Avanza">Avanza</option>
        <option value="Innova">Innova</option>
        <option value="Zenix">Zenix</option>
        <option value="Alphard">Alphard</option>
        <option value="Hiace">Hiace</option>
        <option value="Coaster">Coaster</option>
        <option value="Hilux">Hilux</option>
        <option value="Hilux Fleet">Hilux Fleet</option>
        <option value="Tamaraw">Tamaraw</option>
        <option value="Lite Ace">Lite Ace</option>
      </select>
    </div>
    <div style="margin-bottom:18px;">
      <label for="qbirthdate" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Birthdate</label>
      <input type="date" id="qbirthdate" name="qbirthdate" style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
    </div>
    <div style="margin-bottom:18px;">
      <label for="qaddress" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Complete Address</label>
      <textarea id="qaddress" name="qaddress" rows="2" placeholder="Enter your complete address..." style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px; resize:vertical;"></textarea>
    </div>
    <div style="margin-bottom:18px;">
      <label for="qincome" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Source of Income</label>
      <select id="qincome" name="qincome" style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px; background:#fff;">
        <option value="">Select source of income</option>
        <option value="Employed">Employed</option>
        <option value="Self-Employed">Self-Employed</option>
