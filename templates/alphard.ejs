<!-- FULL SPECS MODAL: ALPHARD 2.5 HEV CVT -->
<div class="specs-modal-overlay" id="specsModalOverlay" aria-hidden="true">
  <div class="specs-modal" role="dialog" aria-modal="true" aria-labelledby="specsModalTitle">
    <div class="specs-modal-header">
      <h2 id="specsModalTitle">Full specs for Alphard 2.5 HEV CVT</h2>
      <button class="specs-close" id="closeSpecsTop" aria-label="Close">×</button>
    </div>

    <div class="specs-modal-content">

      <div class="specs-section">
        <h3>Dimension and Weight</h3>
        <ul class="specs-list">
          <li><span>Overall Dimension (mm)</span><span>5010 x 1850 x 1950</span></li>
          <li><span>Wheelbase (mm)</span><span>3000</span></li>
          <li><span>Seating Capacity</span><span>7</span></li>
        </ul>
      </div>

      <div class="specs-section">
        <h3>Engine</h3>
        <ul class="specs-list">
          <li><span>Engine Type</span><span>Hybrid, 4-cylinder, In-Line, 16-valve DOHC, Chain Drive (With Dual VVT-i)</span></li>
          <li><span>Engine Code</span><span>A25A-FXS</span></li>
          <li><span>Engine Displacement (cc)</span><span>2487</span></li>
          <li><span>Maximum Output (ps/rpm)</span><span>188 / 6000</span></li>
          <li><span>Total System Max Output</span><span>250</span></li>
          <li><span>Maximum Torque (Nm/Rpm)</span><span>233 / 4300-4500</span></li>
          <li><span>Fuel Type</span><span>Gasoline</span></li>
          <li><span>Fuel Capacity (L)</span><span>60</span></li>
        </ul>
      </div>

      <div class="specs-section">
        <h3>Transmission</h3>
        <ul class="specs-list">
