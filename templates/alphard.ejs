    <div class="color" style="background: #999B9B; border: 2px solid #ccc;" onclick="changeColor('gray')" title="Precious Metal"></div>
    <div class="color" style="background: #E5E4E2; border: 2px solid #ccc;" onclick="changeColor('white')" title="Platinum White Pearl Mica"></div>  </div>
</div>

<!-- VARIANTS -->
<div class="section" id="variants">
