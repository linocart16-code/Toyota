        <li>Brakes: Ventilated Disc (front and rear)</li>
        <li>Ignition: Push Start</li>
      </ul>
<div class="full-specs-link" id="openSpecsGCVT">FULL SPECS</div>
    </div>
  </div>
</div>
<!-- FEATURES -->
<div class="features" id="highlights">

  <div class="feature">
    <div class="feature-content">
      <h2>Inspire Awe</h2>
      <p>Sublime design inside and out to captivate admiration</p>
    </div>
    <img src="{{ url_for('static', filename='alphardh1.webp') }}" alt="Cool New Look">
  </div>

  <div class="feature alt">
    <div class="feature-content">
      <h2>Convenience on Demand</h2>
      <p>Easy to access controls that lead to a more pleasant riding experience</p>
    </div>
    <img src="{{ url_for('static', filename='alphardh2.webp') }}" alt="Spacious Comfort">
  </div>

  <div class="feature">
    <div class="feature-content">
      <h2>Blending power and efficiency</h2>
      <p>With the first of its segment hybrid technology, the all-new Toyota Alphard will give you more and impress with less carbon footprint</p>
    </div>
    <img src="{{ url_for('static', filename='alphardh3.webp') }}" alt="Smarter Features">
  </div>


<!-- INSIDE IMAGE -->
<div class="inside-section">
  <img src="{{ url_for('static', filename='alphardh4.webp') }}" alt="Wigo Interior" class="inside-image" id="insideImage">
</div>

<!-- GALLERY -->
  <div class="gallery" id="gallery-section">
  <h2>Gallery</h2>

  <div class="gallery-wrap">
    <button class="gallery-button left" id="gallery-left">‹</button>
    <div class="gallery-track" id="gallery-track">
      <div class="gallery-slide" data-clone="last"><img src="{{ url_for('static', filename='G8.webp') }}" alt="G5"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg1.webp') }}" alt="G1"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg2.webp') }}" alt="G2"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg3.webp') }}" alt="G3"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg4.webp') }}" alt="G4"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg5.webp') }}" alt="G5"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg6.webp') }}" alt="G6"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg7.webp') }}" alt="G7"></div>
      <div class="gallery-slide"><img src="{{ url_for('static', filename='alphardg8.webp') }}" alt="G8"></div>
