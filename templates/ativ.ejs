    </div>
    <div style="margin-bottom:18px;">
      <label for="qbirthdate" style="display:block; margin-bottom:7px; font-weight:600; color:#222;">Birthdate</label>
      <input type="date" id="qbirthdate" name="qbirthdate" style="width:100%; padding:13px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
    </div>
    <div style="margin-bottom:18px;">
