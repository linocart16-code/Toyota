<script>
// Feature scroll animation
document.addEventListener('DOMContentLoaded', function() {
  const features = document.querySelectorAll('.feature');
  function animateFeatures() {
    features.forEach((feature, i) => {
      const rect = feature.getBoundingClientRect();
      if (rect.top < window.innerHeight - 100) {
        if (i % 2 === 0) {
          feature.classList.add('slide-in-left');
        } else {
          feature.classList.add('slide-in-right');
        }
      }
    });
  }
  window.addEventListener('scroll', animateFeatures);
  animateFeatures();
});

// Inside image reveal on scroll
document.addEventListener('DOMContentLoaded', function() {
  const insideImage = document.getElementById('insideImage');
  if (!insideImage) return;

  function revealInsideImage() {
    const rect = insideImage.getBoundingClientRect();
    if (rect.top < window.innerHeight - 80) {
      insideImage.classList.add('show');
    }
  }

  window.addEventListener('scroll', revealInsideImage);
  revealInsideImage();
});
function scrollToSection(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function changeColor(color) {
  const img = document.getElementById("carImage");
  const label = document.getElementById("colorLabel");

  const images = {
    gray: "{{ url_for('static', filename='gray_ativ.webp') }}",
    white: "{{ url_for('static', filename='white_ativ.webp') }}",
    red: "{{ url_for('static', filename='red_ativ.webp') }}",
    whitepearl: "{{ url_for('static', filename='whitepearl_ativ.webp') }}",
    metallic: "{{ url_for('static', filename='metallic_ativ.webp') }}"
  };

  const labels = {
    gray: 'Gray Metallic / Attitude Black Mica',
    white: 'Platinum White Pearl Mica / Attitude Black Mica',
    red: 'Scarlet SE / Attitude Black Mica',
    whitepearl: 'Platinum White Pearl Mica',
    metallic: 'Metal Stream Metallic'
  };

  const fitByColor = {
    gray: 'contain',
    white: 'contain',
    red: 'contain',
    whitepearl: 'contain',
    metallic: 'contain'
  };

  if (images[color]) {
    img.style.objectFit = fitByColor[color] || 'contain';
    img.src = images[color];
    label.textContent = labels[color] || 'ATIV';
  }
}

// Gallery infinite carousel
document.addEventListener('DOMContentLoaded', function(){
  const track = document.getElementById('gallery-track');
  const leftBtn = document.getElementById('gallery-left');
  const rightBtn = document.getElementById('gallery-right');

  let slides = track.querySelectorAll('.gallery-slide');
  let index = 1; // start at first real slide
  let slideWidth = slides[0].getBoundingClientRect().width;
  let isAnimating = false;

  function setPosition(animate = true) {
    track.style.transition = animate ? 'transform 300ms ease' : 'none';
    track.style.transform = `translateX(${-index * slideWidth}px)`;
  }

  function refresh() {
    slides = track.querySelectorAll('.gallery-slide');
    slideWidth = slides[0].getBoundingClientRect().width;
    setPosition(false);
    // re-enable transition next frame
    requestAnimationFrame(()=> track.style.transition = 'transform 300ms ease');
  }

  window.addEventListener('resize', refresh);
  window.addEventListener('load', refresh);

  // initial position after DOM ready
  if (document.readyState === 'complete') {
    refresh();
  } else {
    requestAnimationFrame(refresh);
  }

  rightBtn.addEventListener('click', function(){
    if (isAnimating) return;
    isAnimating = true;
    index++;
    setPosition(true);
  });

  leftBtn.addEventListener('click', function(){
    if (isAnimating) return;

    // If on first real slide, jump to last real slide first (without animation),
    // then move one step left with animation to keep infinite loop smooth.
    if (index <= 1) {
      index = slides.length - 2;
      setPosition(false);
      // force reflow so next transform animates
      track.offsetHeight;
    }

    isAnimating = true;
    index--;
    setPosition(true);
  });

  track.addEventListener('transitionend', function(){
    const current = slides[index];

    // Safety guard for out-of-range indexes
    if (!current) {
      if (index <= 0) index = slides.length - 2;
      if (index >= slides.length - 1) index = 1;
      setPosition(false);
      isAnimating = false;
      return;
    }

    const cloneType = current.dataset.clone;
    if (cloneType === 'first') {
      // jumped to cloned first — go to real first
      index = 1;
      setPosition(false);
    } else if (cloneType === 'last') {
      // jumped to cloned last — go to real last
      index = slides.length - 2;
      setPosition(false);
    }

    isAnimating = false;
  });

});

// Full specs modal behavior (G CVT + E CVT)
document.addEventListener('DOMContentLoaded', function(){
  function setupModal(openId, overlayId, closeTopId, closeTextId) {
    const openBtn = document.getElementById(openId);
    const overlay = document.getElementById(overlayId);
    const closeTop = document.getElementById(closeTopId);
    const closeText = document.getElementById(closeTextId);

    if (!openBtn || !overlay) return null;

    function openModal() {
      overlay.classList.add('show');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      overlay.classList.remove('show');
      overlay.setAttribute('aria-hidden', 'true');
      const anyOpen = document.querySelector('.specs-modal-overlay.show');
      if (!anyOpen) document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', openModal);
    if (closeTop) closeTop.addEventListener('click', closeModal);
    if (closeText) closeText.addEventListener('click', closeModal);

    overlay.addEventListener('click', function(e){
      if (e.target === overlay) closeModal();
    });

    return { overlay, closeModal };
  }

  const gModal = setupModal('openSpecsGCVT', 'specsModalOverlay', 'closeSpecsTop', 'closeSpecsText');
  const eModal = setupModal('openSpecsECVT', 'specsModalOverlayECVT', 'closeSpecsTopECVT', 'closeSpecsTextECVT');
  const jModal = setupModal('openSpecsJMT', 'specsModalOverlayJMT', 'closeSpecsTopJMT', 'closeSpecsTextJMT');

  // Also open modal when variant image is clicked
  const gImageTrigger = document.getElementById('openSpecsGCVTImage');
  const eImageTrigger = document.getElementById('openSpecsECVTImage');
  const jImageTrigger = document.getElementById('openSpecsJMTImage');

  if (gImageTrigger && gModal) gImageTrigger.addEventListener('click', () => gModal.overlay.classList.add('show') || gModal.overlay.setAttribute('aria-hidden', 'false') || (document.body.style.overflow = 'hidden'));
  if (eImageTrigger && eModal) eImageTrigger.addEventListener('click', () => eModal.overlay.classList.add('show') || eModal.overlay.setAttribute('aria-hidden', 'false') || (document.body.style.overflow = 'hidden'));
  if (jImageTrigger && jModal) jImageTrigger.addEventListener('click', () => jModal.overlay.classList.add('show') || jModal.overlay.setAttribute('aria-hidden', 'false') || (document.body.style.overflow = 'hidden'));

  document.addEventListener('keydown', function(e){
    if (e.key !== 'Escape') return;
    if (gModal && gModal.overlay.classList.contains('show')) gModal.closeModal();
    if (eModal && eModal.overlay.classList.contains('show')) eModal.closeModal();
    if (jModal && jModal.overlay.classList.contains('show')) jModal.closeModal();
  });
});
</script>

</body>
</html>