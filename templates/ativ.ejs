    <div style="background:#4CAF50; color:#fff; padding:15px 20px; text-align:center; font-size:16px; font-weight:600;">
      {% for category, message in messages %}
        {{ message }}
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

